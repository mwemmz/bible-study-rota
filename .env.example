# =============================================================================
# Bible Study Rota — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# Server port
PORT=3000

# SQLite database file path (relative to project root)
DB_PATH=./rota.db

# How many weekday sessions to pre-populate on first run
SESSIONS_TO_GENERATE=20

# First session date (YYYY-MM-DD)
START_DATE=2026-07-14

# =============================================================================
# EMAIL CONFIGURATION (choose ONE option below)
# =============================================================================

# --- Option A: Generic SMTP (Gmail, Outlook, etc.) ---
# For Gmail: enable "App Passwords" (2FA required) and use that as SMTP_PASS.
# For Outlook/Hotmail: similar process.
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=your-app-password-here
# SMTP_FROM="Bible Study Rota <your.email@gmail.com>"

# --- Option B: SendGrid (via their SMTP relay) ---
# Sign up at https://sendgrid.com, create an API key, then use:
#
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.your-api-key-here
# SMTP_FROM="Bible Study Rota <notifications@yourdomain.com>"

# --- Option C: Resend (modern API, recommended) ---
# Sign up at https://resend.com, create an API key.
#
# RESEND_API_KEY=re_your_key_here
# RESEND_FROM="Bible Study Rota <rota@yourdomain.com>"

# --- Option D: Ethereal (testing only, no real emails sent) ---
# Great for local development — emails show up in Ethereal's web viewer.
#
USE_ETHEREAL=true
