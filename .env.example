# Bible Study Rota — Environment Configuration
# Copy this file to .env and fill in your values.

# Server port
PORT=3000

# Sessions to pre-populate
SESSIONS_TO_GENERATE=20

# First session date (YYYY-MM-DD)
START_DATE=2026-07-14

# =============================================================================
# DATABASE — Turso (free cloud SQLite)
# =============================================================================
# 1. Sign up at https://turso.tech
# 2. Create a database named "bible-study-rota"
# 3. Copy the URL and auth token below
#
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# =============================================================================
# EMAIL — Gmail SMTP (or choose another option)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM="Bible Study Rota <your.email@gmail.com>"

# --- Or use Ethereal for testing (no real emails) ---
# USE_ETHEREAL=true
